{
  "name": "WAConfig",
  "type": "object",
  "properties": {
    "auto_reply_enabled": {
      "type": "boolean",
      "default": false
    },
    "ai_personality": {
      "type": "string",
      "default": "You are a helpful, professional assistant. Be concise and friendly."
    },
    "business_name": {
      "type": "string"
    },
    "business_hours_start": {
      "type": "string",
      "default": "09:00"
    },
    "business_hours_end": {
      "type": "string",
      "default": "17:00"
    },
    "business_days": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [
        "mon",
        "tue",
        "wed",
        "thu",
        "fri"
      ]
    },
    "after_hours_message": {
      "type": "string",
      "default": "Thanks for reaching out! We're currently outside business hours. We'll get back to you first thing tomorrow."
    },
    "welcome_message": {
      "type": "string",
      "default": "Welcome! How can we help you today?"
    },
    "escalation_keywords": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [
        "urgent",
        "emergency",
        "help",
        "manager",
        "human"
      ]
    },
    "max_ai_replies_per_thread": {
      "type": "number",
      "default": 5,
      "description": "Auto-escalate to human after this many AI replies"
    },
    "default_approval_mode": {
      "type": "string",
      "enum": [
        "auto_send",
        "review_first",
        "review_low_confidence"
      ],
      "default": "review_low_confidence"
    },
    "webhook_connected": {
      "type": "boolean",
      "default": false
    }
  },
  "required": []
}