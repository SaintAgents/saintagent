{
  "name": "Region",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "city",
        "bioregion",
        "state",
        "country"
      ],
      "default": "bioregion"
    },
    "parent_region_id": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "image_url": {
      "type": "string"
    },
    "member_count": {
      "type": "number",
      "default": 0
    },
    "coordinates": {
      "type": "string"
    }
  },
  "required": [
    "name",
    "type"
  ]
}