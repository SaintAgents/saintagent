{
  "name": "DailyLog",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "overview": {
      "type": "string"
    },
    "schedule": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "priority": {
            "type": "string",
            "enum": [
              "High",
              "Medium",
              "Low"
            ]
          },
          "time_block": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "link": {
            "type": "string"
          }
        }
      }
    },
    "in_progress": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "link": {
            "type": "string"
          }
        }
      }
    },
    "completed": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string"
          },
          "mission_id": {
            "type": "string"
          },
          "mission_title": {
            "type": "string"
          },
          "agent_name": {
            "type": "string"
          },
          "ggg_earned": {
            "type": "number"
          },
          "note": {
            "type": "string"
          },
          "link": {
            "type": "string"
          }
        }
      }
    },
    "field_update": {
      "type": "object",
      "properties": {
        "focus": {
          "type": "string"
        },
        "wins": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "insights": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "required": [
    "user_id",
    "date"
  ]
}