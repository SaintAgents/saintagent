{
  "name": "PageConfig",
  "type": "object",
  "properties": {
    "page_name": {
      "type": "string",
      "description": "Internal page name/route"
    },
    "display_name": {
      "type": "string",
      "description": "Human-readable page title"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "hidden",
        "disabled",
        "deleted"
      ],
      "default": "active"
    },
    "category": {
      "type": "string",
      "enum": [
        "core",
        "community",
        "finance",
        "admin",
        "tools",
        "other"
      ],
      "default": "other"
    },
    "icon": {
      "type": "string",
      "description": "Lucide icon name"
    },
    "description": {
      "type": "string"
    },
    "requires_admin": {
      "type": "boolean",
      "default": false
    },
    "sort_order": {
      "type": "number",
      "default": 100
    }
  },
  "required": [
    "page_name",
    "display_name"
  ]
}