{
  "name": "ProductPurchase",
  "type": "object",
  "properties": {
    "buyer_id": {
      "type": "string"
    },
    "buyer_name": {
      "type": "string"
    },
    "buyer_avatar": {
      "type": "string"
    },
    "creator_id": {
      "type": "string"
    },
    "creator_name": {
      "type": "string"
    },
    "product_id": {
      "type": "string"
    },
    "product_title": {
      "type": "string"
    },
    "product_type": {
      "type": "string"
    },
    "price_paid_ggg": {
      "type": "number"
    },
    "status": {
      "type": "string",
      "enum": [
        "completed",
        "refunded"
      ],
      "default": "completed"
    },
    "access_granted": {
      "type": "boolean",
      "default": true
    },
    "download_count": {
      "type": "number",
      "default": 0
    },
    "progress_percent": {
      "type": "number",
      "default": 0,
      "description": "Course completion progress"
    },
    "completed_modules": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "IDs of completed course modules"
    },
    "rating": {
      "type": "number"
    },
    "review": {
      "type": "string"
    }
  },
  "required": [
    "buyer_id",
    "creator_id",
    "product_id",
    "price_paid_ggg"
  ]
}