{
  "name": "PortfolioItem",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "description": "Owner user id (email)"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "link_url": {
      "type": "string",
      "description": "External link to project or repo"
    },
    "image_url": {
      "type": "string",
      "description": "Preview image URL"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "is_featured": {
      "type": "boolean",
      "default": false
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "archived"
      ],
      "default": "active"
    }
  },
  "required": [
    "user_id",
    "title"
  ]
}