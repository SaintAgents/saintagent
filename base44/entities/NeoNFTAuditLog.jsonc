{
  "name": "NeoNFTAuditLog",
  "type": "object",
  "properties": {
    "neo_nft_id": {
      "type": "string"
    },
    "neo_nft_title": {
      "type": "string"
    },
    "action_type": {
      "type": "string",
      "enum": [
        "mint",
        "transfer",
        "custody_change",
        "geo_fence_update",
        "dna_gate_activation",
        "dna_gate_deactivation",
        "escrow_created",
        "escrow_released",
        "escrow_reverted",
        "document_added",
        "document_verified",
        "price_update",
        "listing_created",
        "listing_removed",
        "verification_status_change",
        "restriction_update",
        "zone_compliance_check"
      ]
    },
    "actor_id": {
      "type": "string",
      "description": "User who performed the action"
    },
    "actor_name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "previous_value": {
      "type": "string"
    },
    "new_value": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "description": "Additional action-specific data"
    },
    "starchain_tx_hash": {
      "type": "string"
    },
    "block_number": {
      "type": "number"
    },
    "is_immutable": {
      "type": "boolean",
      "default": true
    },
    "compliance_relevant": {
      "type": "boolean",
      "default": false
    },
    "geo_location": {
      "type": "string",
      "description": "Geographic location where action occurred"
    }
  },
  "required": [
    "neo_nft_id",
    "action_type",
    "actor_id",
    "description"
  ]
}