{
  "name": "CircleMessage",
  "type": "object",
  "properties": {
    "circle_id": {
      "type": "string"
    },
    "author_id": {
      "type": "string"
    },
    "author_name": {
      "type": "string"
    },
    "author_avatar": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "message_type": {
      "type": "string",
      "enum": [
        "text",
        "image",
        "file",
        "system"
      ],
      "default": "text"
    },
    "file_url": {
      "type": "string"
    },
    "is_pinned": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "circle_id",
    "author_id",
    "content"
  ]
}