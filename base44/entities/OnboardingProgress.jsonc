{
  "name": "OnboardingProgress",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "not_started",
        "in_progress",
        "complete"
      ],
      "default": "not_started"
    },
    "current_step": {
      "type": "number",
      "default": 0
    },
    "completed_steps": {
      "type": "array",
      "items": {
        "type": "number"
      },
      "default": []
    },
    "step_data": {
      "type": "object",
      "default": {}
    },
    "tour_completed": {
      "type": "boolean",
      "default": false,
      "description": "True if the user has completed the initial app tour"
    }
  },
  "required": [
    "user_id"
  ]
}