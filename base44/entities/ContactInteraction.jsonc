{
  "name": "ContactInteraction",
  "type": "object",
  "properties": {
    "contact_id": {
      "type": "string",
      "description": "Reference to Contact"
    },
    "contact_name": {
      "type": "string"
    },
    "contact_email": {
      "type": "string"
    },
    "owner_id": {
      "type": "string",
      "description": "CRM user who owns this interaction"
    },
    "interaction_type": {
      "type": "string",
      "enum": [
        "email_sent",
        "email_received",
        "meeting",
        "call",
        "note",
        "file"
      ],
      "description": "Type of interaction"
    },
    "subject": {
      "type": "string",
      "description": "Email subject or meeting title"
    },
    "summary": {
      "type": "string",
      "description": "Brief summary or snippet"
    },
    "external_id": {
      "type": "string",
      "description": "Gmail message ID or Calendar event ID for dedup"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time",
      "description": "When the interaction happened"
    },
    "duration_minutes": {
      "type": "number",
      "description": "Duration for meetings/calls"
    },
    "attendees": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "Email addresses of participants"
    },
    "source": {
      "type": "string",
      "enum": [
        "gmail",
        "google_calendar",
        "manual",
        "zoom"
      ],
      "default": "manual"
    },
    "metadata": {
      "type": "object",
      "description": "Additional data (labels, location, etc.)"
    }
  },
  "required": [
    "owner_id",
    "interaction_type"
  ]
}