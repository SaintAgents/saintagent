{
  "name": "ListingReview",
  "type": "object",
  "properties": {
    "listing_id": {
      "type": "string",
      "description": "Reference to the listing being reviewed"
    },
    "listing_title": {
      "type": "string"
    },
    "seller_id": {
      "type": "string",
      "description": "Listing owner email"
    },
    "reviewer_id": {
      "type": "string",
      "description": "Email of the reviewer"
    },
    "reviewer_name": {
      "type": "string"
    },
    "reviewer_avatar": {
      "type": "string"
    },
    "rating": {
      "type": "number",
      "minimum": 1,
      "maximum": 5,
      "description": "Overall rating 1-5"
    },
    "communication_rating": {
      "type": "number",
      "minimum": 1,
      "maximum": 5
    },
    "quality_rating": {
      "type": "number",
      "minimum": 1,
      "maximum": 5
    },
    "value_rating": {
      "type": "number",
      "minimum": 1,
      "maximum": 5
    },
    "comment": {
      "type": "string"
    },
    "would_recommend": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "listing_id",
    "seller_id",
    "reviewer_id",
    "rating"
  ]
}