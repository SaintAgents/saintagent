{
  "name": "ProjectMilestone",
  "type": "object",
  "properties": {
    "project_id": {
      "type": "string",
      "description": "Reference to Project"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "order": {
      "type": "number",
      "default": 0,
      "description": "Display order within project"
    },
    "start_date": {
      "type": "string",
      "format": "date"
    },
    "end_date": {
      "type": "string",
      "format": "date"
    },
    "status": {
      "type": "string",
      "enum": [
        "planned",
        "in_progress",
        "completed",
        "on_hold"
      ],
      "default": "planned"
    },
    "progress_percent": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "project_id",
    "name"
  ]
}