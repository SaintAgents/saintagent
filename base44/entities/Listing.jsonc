{
  "name": "Listing",
  "type": "object",
  "properties": {
    "owner_id": {
      "type": "string"
    },
    "owner_name": {
      "type": "string"
    },
    "owner_avatar": {
      "type": "string"
    },
    "entity_id": {
      "type": "string",
      "description": "BusinessEntity5D ID if posted on behalf of a business"
    },
    "entity_name": {
      "type": "string",
      "description": "Business entity name"
    },
    "entity_logo": {
      "type": "string",
      "description": "Business entity logo URL"
    },
    "listing_type": {
      "type": "string",
      "enum": [
        "offer",
        "request"
      ],
      "default": "offer"
    },
    "category": {
      "type": "string",
      "enum": [
        "mentorship",
        "course",
        "session",
        "consulting",
        "healing",
        "mutual_aid",
        "collaboration",
        "strategy",
        "legal",
        "ai_prompts",
        "web_dev",
        "design",
        "governance",
        "finance",
        "digital_rights",
        "writing"
      ],
      "default": "session"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "price_amount": {
      "type": "number",
      "default": 0
    },
    "price_ggg": {
      "type": "number",
      "default": 0,
      "description": "Price in GGG tokens"
    },
    "time_credits": {
      "type": "number",
      "default": 0,
      "description": "Total time credits for this service"
    },
    "credits_per_hour": {
      "type": "number",
      "default": 1,
      "description": "Provider's hourly credit rate"
    },
    "payment_type": {
      "type": "string",
      "enum": [
        "ggg_only",
        "time_only",
        "hybrid",
        "fiat"
      ],
      "default": "fiat"
    },
    "is_free": {
      "type": "boolean",
      "default": false
    },
    "duration_minutes": {
      "type": "number",
      "default": 60
    },
    "delivery_mode": {
      "type": "string",
      "enum": [
        "online",
        "in-person",
        "hybrid"
      ],
      "default": "online"
    },
    "region": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "paused",
        "sold_out"
      ],
      "default": "active"
    },
    "views_count": {
      "type": "number",
      "default": 0
    },
    "requests_count": {
      "type": "number",
      "default": 0
    },
    "bookings_count": {
      "type": "number",
      "default": 0
    },
    "rating": {
      "type": "number"
    },
    "image_url": {
      "type": "string"
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "skills_required": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "revisions_included": {
      "type": "number",
      "default": 1
    },
    "delivery_days": {
      "type": "number",
      "default": 7
    },
    "portfolio_urls": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "recurring_available": {
      "type": "boolean",
      "default": false,
      "description": "Whether this listing accepts recurring bookings"
    },
    "recurring_availability": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "day_of_week": {
            "type": "number",
            "description": "0=Sun, 6=Sat"
          },
          "start_time": {
            "type": "string",
            "description": "HH:MM"
          },
          "end_time": {
            "type": "string",
            "description": "HH:MM"
          }
        }
      },
      "default": [],
      "description": "Provider's recurring availability windows"
    }
  },
  "required": [
    "owner_id",
    "title"
  ]
}