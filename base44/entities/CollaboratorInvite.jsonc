{
  "name": "CollaboratorInvite",
  "type": "object",
  "properties": {
    "project_id": {
      "type": "string"
    },
    "project_title": {
      "type": "string"
    },
    "inviter_id": {
      "type": "string"
    },
    "inviter_name": {
      "type": "string"
    },
    "invitee_id": {
      "type": "string"
    },
    "invitee_email": {
      "type": "string"
    },
    "role": {
      "type": "string",
      "enum": [
        "viewer",
        "commenter",
        "editor",
        "co-author"
      ],
      "default": "editor"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "accepted",
        "declined",
        "expired"
      ],
      "default": "pending"
    },
    "message": {
      "type": "string"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "project_id",
    "inviter_id",
    "invitee_id"
  ]
}