{
  "name": "BadgeDefinition",
  "type": "object",
  "properties": {
    "badge_code": {
      "type": "string",
      "description": "Unique code for the badge type"
    },
    "badge_name": {
      "type": "string",
      "description": "Display name of the badge"
    },
    "category": {
      "type": "string",
      "enum": [
        "identity",
        "marketplace",
        "agent",
        "security",
        "mission",
        "alignment",
        "achievement",
        "streak",
        "social",
        "soul_resonance",
        "quest_type",
        "verification"
      ],
      "default": "achievement",
      "description": "Category of the badge"
    },
    "description": {
      "type": "string",
      "description": "Description of how to earn this badge"
    },
    "icon_url": {
      "type": "string",
      "description": "URL to badge icon image"
    },
    "ggg_reward": {
      "type": "number",
      "default": 0,
      "description": "GGG amount awarded when badge is earned"
    },
    "rarity": {
      "type": "string",
      "enum": [
        "common",
        "uncommon",
        "rare",
        "epic",
        "legendary"
      ],
      "default": "common"
    },
    "quest_id": {
      "type": "string",
      "description": "Associated quest ID if any"
    },
    "quest_type": {
      "type": "string",
      "enum": [
        "solo",
        "paired",
        "team",
        "none"
      ],
      "default": "none",
      "description": "Type of quest required to earn this badge"
    },
    "objectives": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "target_count": {
            "type": "number"
          },
          "required": {
            "type": "boolean"
          }
        }
      },
      "default": [],
      "description": "Objectives required to earn badge"
    },
    "is_active": {
      "type": "boolean",
      "default": true,
      "description": "Whether this badge can be earned"
    },
    "sort_order": {
      "type": "number",
      "default": 0,
      "description": "Display order within category"
    }
  },
  "required": [
    "badge_code",
    "badge_name"
  ]
}