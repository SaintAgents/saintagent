{
  "name": "GroupPostReply",
  "type": "object",
  "properties": {
    "post_id": {
      "type": "string"
    },
    "circle_id": {
      "type": "string"
    },
    "author_id": {
      "type": "string"
    },
    "author_name": {
      "type": "string"
    },
    "author_avatar": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "parent_reply_id": {
      "type": "string",
      "description": "For nested replies"
    },
    "likes_count": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "post_id",
    "author_id",
    "content"
  ]
}